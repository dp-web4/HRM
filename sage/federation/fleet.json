{
  "fleet_version": 3,
  "description": "SAGE fleet manifest — static registry of all machines. Identity is anchored to lct_id (immutable). IPs are last-known and may be stale — use mDNS for discovery.",
  "discovery": {
    "method": "mdns",
    "fallback_order": ["mdns", "last_seen_ip", "static_ip"],
    "mdns_timeout_ms": 500,
    "ip_cache_ttl_seconds": 3600,
    "gossip_enabled": true
  },
  "identity_tiers": {
    "immutable": ["lct_id", "hardware_ek"],
    "characteristic": ["hostname", "mdns_name", "mac_address"],
    "dynamic": ["gateway_host", "last_seen_ip", "last_seen_at", "model_default"]
  },
  "resource_pools": {
    "synthesis": {
      "machines": ["thor", "sprout", "legion", "mcnugget"],
      "account": 1,
      "role": "generative — code, implementations, large agent tasks",
      "weekly_reset": "thursday_21:00_local",
      "session_reset_hours": 5,
      "relative_budget": "large"
    },
    "oversight": {
      "machines": ["cbp", "nomad"],
      "account": 2,
      "role": "review, planning, documentation, coordination, unblocking",
      "weekly_reset": null,
      "session_reset_hours": 5,
      "relative_budget": "baseline"
    }
  },
  "machines": {
    "thor": {
      "pool": "synthesis",
      "lct_id": "thor_sage_lct",
      "mdns_name": "thor.local",
      "gateway_host": "10.0.0.210",
      "last_seen_ip": "10.0.0.210",
      "last_seen_at": null,
      "gateway_port": 8750,
      "federation_port": 50051,
      "model_default": "qwen3.5:27b",
      "device": "cuda",
      "hardware": "Jetson AGX Thor"
    },
    "sprout": {
